# ============================================================
# Sitara Website — Environment Variables
# Copy this file to .env.local and fill in the values.
# ============================================================

# ── Kora backend ────────────────────────────────────────────
# Base URL of the Kora API (server-side only, never sent to browser)
KORA_API_URL=https://your-kora-api-url.com

# Tenant API key — generated once in Kora per tenant, shown only on creation.
# Add via: Kora admin → Tenant settings → Generate API Key
# Store in Vercel: Settings → Environment Variables → KORA_TENANT_API_KEY
KORA_TENANT_API_KEY=kora_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tenant code for this deployment — identifies which Kora tenant this site
# belongs to. Found in: Kora DB → tenants.code  (not a secret, safe for browser)
# Each new tenant deployment gets its own value here.
NEXT_PUBLIC_KORA_TENANT_CODE=your-tenant-code-here

# ── Contact form (Resend) ────────────────────────────────────
SITARA_CONTACT_TO=metals@your-domain.com
SITARA_CONTACT_FROM=Your Brand <no-reply@your-domain.com>
SITARA_CONTACT_CONFIRM_TO=

# ── Branding ────────────────────────────────────────────────
SITARA_BRAND_NAME=Sitara
NEXT_PUBLIC_BASE_PATH=
